PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=one8

# JWT Secrets
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Delivery Configuration (Choose either Brevo or Resend API)
# Option A: Brevo API (Supports free sending using a verified sender email address - no domain required)
BREVO_API_KEY=your_brevo_api_key
# Option B: Resend API (Requires a custom domain for sending to external recipients)
RESEND_API_KEY=your_resend_api_key

# The sender email address (For Brevo, use your verified sender email. For Resend, use onboarding@resend.dev or your custom domain email)
EMAIL_FROM=onboarding@resend.dev
